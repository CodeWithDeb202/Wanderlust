<% layout("/layouts/boilerplate.ejs") %>

<link rel="stylesheet" href="/css/index.css">

    <body>

        <div id="filters">
            <div class="filters_list">
                <div class="filter <%= !selectedCategory ? 'active' : '' %>">
                    <a href="/listings">
                        <div><i class="fa-solid fa-fire"></i></div>
                        <p>Trending</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Rooms' ? 'active' : '' %>">
                    <a href="/listings?category=Rooms">
                        <div><i class="fa-solid fa-bed"></i></div>
                        <p>Rooms</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Iconic cities' ? 'active' : '' %>">
                    <a href="/listings?category=Iconic%20cities">
                        <div><i class="fa-solid fa-mountain-city"></i></div>
                        <p>Iconic cities</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Mountains' ? 'active' : '' %>">
                    <a href="/listings?category=Mountains">
                        <div><i class="fa-solid fa-mountain"></i></div>
                        <p>Mountains</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Castles' ? 'active' : '' %>">
                    <a href="/listings?category=Castles">
                        <div><i class="fa-brands fa-fort-awesome"></i></div>
                        <p>Castles</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Amazing pools' ? 'active' : '' %>">
                    <a href="/listings?category=Amazing%20pools">
                        <div><i class="fa-solid fa-person-swimming"></i></div>
                        <p>Amazing pools</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Camping' ? 'active' : '' %>">
                    <a href="/listings?category=Camping">
                        <div><i class="fa-solid fa-tent"></i></div>
                        <p>Camping</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Beach' ? 'active' : '' %>">
                    <a href="/listings?category=Beach">
                        <div><i class="fa-solid fa-umbrella-beach"></i></div>
                        <p>Beach</p>
                    </a>
                </div>
                <div class="filter <%= selectedCategory === 'Farms' ? 'active' : '' %>">
                    <a href="/listings?category=Farms">
                        <div><i class="fa-solid fa-seedling"></i></div>
                        <p>Farms</p>
                    </a>
                </div>
            </div>

            <div class="tax_toggle">
                <div class="form-check-reverse form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                    <label class="form-check-label" for="switchCheckDefault">Display Taxes</label>
                </div>
            </div>

        </div>

        <% if (searchCountry) { %>
            <p class="mt-3 mb-0 text-muted">Showing results for "<%= searchCountry %>"</p>
        <% } %>

        <% if (allListing.length === 0) { %>
            <h5 class="mt-4 text-muted">No listings found.</h5>
        <% } %>

        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
            <% for (let listing of allListing) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">

                    <div class="card col listing-card">
                        <% if (listing.image && listing.image.url) { %>
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
                        <% } else { %>
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light text-muted"
                                style="height: 20rem;">
                                No image available
                            </div>
                        <% } %>

                        <div class="card-img-overlay"></div>

                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= listing.title %>
                                </b> <br>
                                &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                                <i class="tax_info">&nbsp;&nbsp;&nbsp;&nbsp;+18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>
            <% } %>
        </div>

        <script src="/js/index.js"></script>
    </body>
