<% layout("/layouts/boilerplate.ejs") %>

    <body>
        <h3 class="mt-3 mb-3">
            <%= listing.title %>
        </h3>
        <div class="row">
            <div class="col offset-2">
                <div class="card col-6 listing-card">
                    <% if (listing.image && listing.image.url) { %>
                        <img src="<%= listing.image.url %>" class="card-img-top show_img mb-3" alt="listing_image">
                    <% } else { %>
                        <div class="show_img mb-3 d-flex align-items-center justify-content-center bg-light text-muted">
                            No image available
                        </div>
                    <% } %>
                    <div class="card-body">

                        <p class="card-text">
                            <i><b>Owned by: <%= listing.owner ? listing.owner.username : "Unknown user" %></b></i>
                        </p>

                        <p class="card-text">
                            <b>Description:</b>
                            <%= listing.description %>
                        </p>

                        <p class="card-text">
                            <b>Price:</b> <b>&#8377;<%= listing.price.toLocaleString("en-IN")%></b>
                        </p>

                        <p class="card-text">
                            <b>Country:</b>
                            <%= listing.country %>
                        </p>

                        <p class="card-text">
                            <b>Location:</b>
                            <%= listing.location %>
                        </p>
                    </div>

                </div>
            </div>

            <% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
                <div class="row mt-3 mb-3">
                    <div class="mb-3 col-md-4">
                        <a class="btn btn-dark col-4 offset-7  edit-btn"
                            href="/listings/<%= listing._id %>/edit">Edit</a>
                    </div>

                    <div class="mb-3 col-md-4">
                        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                            <button class="btn btn-dark col-4 dlt-btn">Delete</button>
                        </form>
                    </div>
                </div>
                <% } %>


                    <div class="col-8 offset-2 mb-3">
                        <hr>
                        <% if(currentUser) { %>
                            <h4>Leave a Review</h4>
                            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate
                                class="needs-validation">
                                <div class="mb-3 mt-3">
                                    <label for="rating" class="form-label">Rating</label>
                                    <fieldset class="starability-slot">
                                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                        checked aria-label="No rating." />
                                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                        <label for="first-rate1" title="Terrible">1 star</label>
                                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                        <label for="first-rate2" title="Not good">2 stars</label>
                                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                        <label for="first-rate3" title="Average">3 stars</label>
                                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                        <label for="first-rate4" title="Very good">4 stars</label>
                                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                        <label for="first-rate5" title="Amazing">5 stars</label>
                                    </fieldset>
                                </div>

                                <div class="mb-3 mt-3">
                                    <label for="comment" class="form-label">Comments</label>
                                    <textarea class="form-control" id="comment" name="review[comment]" cols="20"
                                        rows="5" required></textarea>
                                    <div class="invalid-feedback">Please submit some comments for review</div>
                                </div>

                                <button class="btn btn-outline-dark">Submit</button>
                            </form>
                            <hr>
                        <% } %>

                            <p><b>All Reviews!!</b></p>
                            <div class="row">
                                    <% for(let review of listing.review){ %>
                                        <div class="card mb-3 col-5 ms-3">
                                            <div class="card-body">
                                                <h5 class="card-title">@<%= review.author ? review.author.username
                                                        : "deleted-user" %>
                                                </h5>
                                                <p class="card-text">
                                                    <%= review.comment %>
                                                </p>

                                                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                                                <% if(currentUser !== review.author) { %>
                                                    <form
                                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                        method="post" class="mb-3">
                                                        <button class="btn btn-sm btn-dark">Delete</button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% } %>
                            </div>

                    </div>
        </div>

    </body>
